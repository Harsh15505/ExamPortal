# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Database Configuration (Hosted MySQL)
DB_ENGINE=django.db.backends.mysql
DB_NAME=exam_system
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your-mysql-server.com
DB_PORT=3306

# Optional: SSL Configuration for hosted MySQL
# Uncomment and fill if your provider requires SSL
# DB_SSL_CA=/path/to/ca.pem
# DB_SSL_VERIFY_CERT=True
# DB_SSL_VERIFY_IDENTITY=True

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-domain.com

# API Configuration
API_TIMEOUT=30
